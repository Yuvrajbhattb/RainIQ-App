<!-- Glass card for the floating "Rain collected" stat overlay -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark glass body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CC0D1A0D" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Top specular highlight -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Rim border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#44FFFFFF" />
        </shape>
    </item>
</layer-list>
