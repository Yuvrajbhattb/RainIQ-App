<?xml version="1.0" encoding="utf-8"?>
<!-- Primary CTA Button — lime → teal gradient with reduced glow -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/accent_lime_dark">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="180"
                android:startColor="#C8E632"
                android:endColor="#4ECDC4" />
            <corners android:radius="@dimen/radius_button_primary" />
        </shape>
    </item>
</ripple>
