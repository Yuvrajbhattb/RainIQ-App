<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_glass_card.xml — L2 Liquid Glass Card
    iOS-style: frosted body + top-edge specular prism highlight + bright rim
    3-layer system:
      Layer 1: Glass body (dark-green semi-transparent base)
      Layer 2: Top specular — fades from bright white → transparent (prism catch)
      Layer 3: Rim stroke — bright white border (the glass edge)
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Glass body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_primary" />
            <corners android:radius="@dimen/radius_card_primary" />
        </shape>
    </item>

    <!-- Layer 2: Top specular highlight — tight prism at top edge only -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glass_specular_top"
                android:centerColor="@color/glass_specular_mid"
                android:endColor="#00FFFFFF"
                android:centerY="0.25" />
            <corners android:radius="@dimen/radius_card_primary" />
        </shape>
    </item>

    <!-- Layer 3: Bright glass rim border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_card_primary" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_rim_outer" />
        </shape>
    </item>

</layer-list>
