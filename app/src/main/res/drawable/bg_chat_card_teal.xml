<!-- AI chat preview card — glass body with teal accent border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Glass body (slightly deeper teal tint) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A0D2420" />
            <corners android:radius="@dimen/radius_card_primary" />
        </shape>
    </item>

    <!-- Layer 2: Top specular highlight -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#1AFFFFFF"
                android:endColor="#00FFFFFF"
                android:centerY="0.2" />
            <corners android:radius="@dimen/radius_card_primary" />
        </shape>
    </item>

    <!-- Layer 3: Teal accent rim border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_card_primary" />
            <stroke
                android:width="1dp"
                android:color="#664ECDC4" />
        </shape>
    </item>

</layer-list>
