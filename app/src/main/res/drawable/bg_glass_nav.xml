<?xml version="1.0" encoding="utf-8"?>
<!-- Glass nav bar background — frosted translucent -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_nav" />
            <corners android:radius="@dimen/radius_nav_bar" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="@color/glass_specular_mid"
                android:endColor="#00FFFFFF"
                android:centerY="0.25" />
            <corners android:radius="@dimen/radius_nav_bar" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_nav_bar" />
            <stroke android:width="1dp" android:color="@color/glass_rim_outer" />
        </shape>
    </item>
</layer-list>
