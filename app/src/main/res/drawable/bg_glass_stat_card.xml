<?xml version="1.0" encoding="utf-8"?>
<!-- Stat metric card — 20dp radius, same liquid glass 3-layer treatment -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_primary" />
            <corners android:radius="@dimen/radius_card_stat" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="@color/glass_specular_top"
                android:centerColor="@color/glass_specular_mid"
                android:endColor="#00FFFFFF" android:centerY="0.25" />
            <corners android:radius="@dimen/radius_card_stat" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_card_stat" />
            <stroke android:width="1dp" android:color="@color/glass_rim_outer" />
        </shape>
    </item>
</layer-list>
