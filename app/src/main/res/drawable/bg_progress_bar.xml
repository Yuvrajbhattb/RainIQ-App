<?xml version="1.0" encoding="utf-8"?>
<!-- Progress bar drawable — water usage metric in teal (split meaning) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="4dp" />
            <solid android:color="@color/inner_card_bg" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="4dp" />
                <!-- Teal = water usage metric (not lime = achievement) -->
                <gradient
                    android:type="linear"
                    android:angle="0"
                    android:startColor="#4ECDC4"
                    android:endColor="#C8E632" />
            </shape>
        </clip>
    </item>
</layer-list>
