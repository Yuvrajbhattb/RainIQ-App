<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_nav_add_glass.xml — Center "+" action button in nav bar
    Premium convex glass orb with lime specular top (action identity)
    Matches upgraded nav circle system — same 4-layer convex treatment.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow base -->
    <item android:top="2dp" android:left="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/glass_rim_inner" />
        </shape>
    </item>

    <!-- Glass body with lime tint -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/glass_nav_circle" />
        </shape>
    </item>

    <!-- Lime tint overlay — subtle action identity -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="oval">
            <solid android:color="#1AC8E632" />
        </shape>
    </item>

    <!-- Top specular with slight lime tint — prism on action button -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glass_specular_top"
                android:centerColor="#18FFFFFF"
                android:endColor="#00FFFFFF"
                android:centerY="0.4" />
        </shape>
    </item>

    <!-- Lime-white rim border -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="oval">
            <stroke
                android:width="1.5dp"
                android:color="#50C8E632" />
        </shape>
    </item>

</layer-list>
