<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher_foreground.xml — RainIQ App Icon: Variant A
    Liquid Glass Water Drop — teal/aqua on deep forest green
    Design: Premium water drop with:
      - Teal gradient fill (#7AE8E2 → #4ECDC4 → #2A9E96)
      - White specular prism highlight (upper-left)
      - Wave line inside drop bottom (water storage identity)
      - Three tiny rain droplets above (rain harvesting)
      - Teal rim border (glass edge)
    108×108dp canvas (Android adaptive icon safe zone = 72dp centered)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <defs>
        <!-- Main drop teal gradient (top-light to bottom-deep) -->
        <linearGradient
            android:id="@+id/dropGradient"
            android:startX="38" android:startY="18"
            android:endX="70" android:endY="88"
            android:type="linear" />
    </defs>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- GROUP: centered in the 108dp safe zone          -->
    <!-- ═══════════════════════════════════════════════ -->
    <group
        android:translateX="0"
        android:translateY="0">

        <!-- ─────────────────────────────────────────── -->
        <!-- RAIN DROPS (3 tiny dots above main drop)    -->
        <!-- ─────────────────────────────────────────── -->

        <!-- Rain drop left -->
        <path
            android:fillColor="#7AE8E2"
            android:pathData="M41,20 C41,20 40,18 41,17 C42,18 42,20 41,20Z" />

        <!-- Rain drop center -->
        <path
            android:fillColor="#A0EDE9"
            android:pathData="M54,16 C54,16 53,14 54,13 C55,14 55,16 54,16Z" />

        <!-- Rain drop right -->
        <path
            android:fillColor="#7AE8E2"
            android:pathData="M67,20 C67,20 66,18 67,17 C68,18 68,20 67,20Z" />

        <!-- ─────────────────────────────────────────── -->
        <!-- MAIN DROP — outer teal rim (glass border)   -->
        <!-- ─────────────────────────────────────────── -->
        <path
            android:fillColor="#4ECDC4"
            android:pathData="M54,22
                C54,22 32,50 32,65
                C32,77.7 41.8,87 54,87
                C66.2,87 76,77.7 76,65
                C76,50 54,22 54,22Z" />

        <!-- ─────────────────────────────────────────── -->
        <!-- MAIN DROP — deep gradient body              -->
        <!-- gradient: top #7AE8E2 → mid #4ECDC4 → bottom #1E8A83 -->
        <!-- ─────────────────────────────────────────── -->

        <!-- Deep teal base (darkest — bottom glow) -->
        <path
            android:fillColor="#1E8A83"
            android:pathData="M54,24
                C54,24 34,52 34,66
                C34,77.6 43,85 54,85
                C65,85 74,77.6 74,66
                C74,52 54,24 54,24Z" />

        <!-- Mid teal overlay (main body color) -->
        <path
            android:fillColor="#4ECDC4"
            android:alpha="0.85"
            android:pathData="M54,26
                C54,26 36,53 36,66
                C36,76.8 44.2,84 54,84
                C63.8,84 72,76.8 72,66
                C72,53 54,26 54,26Z" />

        <!-- Top-light teal (frosted top portion) -->
        <path
            android:fillColor="#7AE8E2"
            android:alpha="0.70"
            android:pathData="M54,28
                C54,28 40,48 38,60
                C42,52 50,36 54,28Z" />

        <!-- ─────────────────────────────────────────── -->
        <!-- GLASS SPECULAR — upper-left prism highlight -->
        <!-- The key iOS liquid glass signature          -->
        <!-- ─────────────────────────────────────────── -->

        <!-- Large soft specular blob -->
        <path
            android:fillColor="#FFFFFF"
            android:alpha="0.35"
            android:pathData="M46,32
                C44,36 40,46 40,54
                C40,54 38,50 40,44
                C42,38 46,32 46,32Z" />

        <!-- Bright tight specular core (the prism peak) -->
        <path
            android:fillColor="#FFFFFF"
            android:alpha="0.70"
            android:pathData="M50,30
                C49,33 47,37 47,40
                C47,37 49,33 50,30Z" />

        <!-- ─────────────────────────────────────────── -->
        <!-- WAVE INSIDE DROP (water storage identity)   -->
        <!-- Subtle white wave across the lower body     -->
        <!-- ─────────────────────────────────────────── -->
        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.2"
            android:strokeAlpha="0.45"
            android:fillColor="#00000000"
            android:pathData="M40,70 Q47,66 54,70 Q61,74 68,70" />

        <!-- Second wave (lower, fainter) -->
        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="0.8"
            android:strokeAlpha="0.25"
            android:fillColor="#00000000"
            android:pathData="M41,76 Q47.5,72 54,76 Q60.5,80 67,76" />

        <!-- ─────────────────────────────────────────── -->
        <!-- OUTER RIM — bright teal glass edge          -->
        <!-- ─────────────────────────────────────────── -->
        <path
            android:strokeColor="#7AE8E2"
            android:strokeWidth="1.0"
            android:strokeAlpha="0.60"
            android:fillColor="#00000000"
            android:pathData="M54,22
                C54,22 32,50 32,65
                C32,77.7 41.8,87 54,87
                C66.2,87 76,77.7 76,65
                C76,50 54,22 54,22Z" />

        <!-- ─────────────────────────────────────────── -->
        <!-- BOTTOM GLOW — soft teal radiance under drop -->
        <!-- ─────────────────────────────────────────── -->
        <path
            android:fillColor="#4ECDC4"
            android:alpha="0.12"
            android:pathData="M38,87 Q54,95 70,87 Q62,92 54,92 Q46,92 38,87Z" />

    </group>

</vector>
