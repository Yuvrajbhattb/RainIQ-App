<?xml version="1.0" encoding="utf-8"?>
<!-- Insight card — lime-tinted glass variant -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/insight_bg_tint" />
            <corners android:radius="@dimen/radius_card_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#33C8E632"
                android:centerColor="#10C8E632"
                android:endColor="#00C8E632"
                android:centerY="0.3" />
            <corners android:radius="@dimen/radius_card_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_card_primary" />
            <stroke android:width="1dp" android:color="#40C8E632" />
        </shape>
    </item>
</layer-list>
