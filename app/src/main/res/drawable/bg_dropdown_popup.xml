<?xml version="1.0" encoding="utf-8"?>
<!-- Designed and Developed by Rahul Mirji -->
<!-- Dropdown popup container — glass card with teal accent border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Dark glass body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F0111D0F" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Layer 2: Top specular highlight -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#1AFFFFFF"
                android:endColor="#00FFFFFF"
                android:centerY="0.15" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Layer 3: Subtle rim border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#45FFFFFF" />
        </shape>
    </item>

</layer-list>
