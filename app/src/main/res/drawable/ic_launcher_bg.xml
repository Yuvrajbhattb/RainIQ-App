<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher_bg.xml — App icon background
    Deep dark green → forest green gradient (not pure black)
    Creates contrast with the teal water drop foreground
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="radial"
        android:gradientRadius="80%"
        android:startColor="#152010"
        android:endColor="#0A150A" />
</shape>
