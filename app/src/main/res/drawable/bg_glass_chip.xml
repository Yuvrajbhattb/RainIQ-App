<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_glass_chip.xml — Small chip / icon container glass
    Used for: icon backing circles in cards, filter chips, small badges
    iOS reference: clearly visible frosted disc with a bright rim
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Glass body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_chip" />
            <corners android:radius="@dimen/radius_chip" />
        </shape>
    </item>

    <!-- Top specular highlight -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glass_specular_mid"
                android:endColor="#00FFFFFF"
                android:centerY="0.4" />
            <corners android:radius="@dimen/radius_chip" />
        </shape>
    </item>

    <!-- Rim border — clearly visible glass edge -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_chip" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_rim_outer" />
        </shape>
    </item>

</layer-list>
