<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fillViewport="false" android:clipToPadding="false"
    android:overScrollMode="never" android:paddingTop="116dp" android:paddingBottom="160dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="TODAY'S TIPS FOR YOU" android:textColor="@color/accent_teal"
            android:textSize="10sp" android:fontFamily="@font/sf_pro_display_medium"
            android:letterSpacing="0.12" android:layout_marginBottom="12dp" />
        <!-- Tip 1 - Featured -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_ai_card" android:padding="20dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/bg_glass_chip" android:layout_marginEnd="12dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_gravity="center" android:src="@drawable/ic_sparkle" android:tint="@color/accent_teal" />
                    </FrameLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Pre-Monsoon Setup Tip"
                        android:textColor="@color/accent_teal" android:textSize="13sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="High Impact" android:textColor="@color/accent_lime"
                        android:textSize="10sp" android:fontFamily="@font/sf_pro_display_medium"
                        android:background="@drawable/bg_glass_chip" android:padding="6dp" />
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Clean your roof gutters before the monsoon begins. Debris can reduce your harvest efficiency by up to 30%. A quick sweep can save you thousands of litres this season!"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:lineSpacingExtra="4sp" />
            </LinearLayout>
        </FrameLayout>
        <!-- Tip 2 -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_ai_card" android:padding="20dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/bg_glass_chip" android:layout_marginEnd="12dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_gravity="center" android:src="@drawable/ic_drop" android:tint="@color/accent_teal" />
                    </FrameLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="First Flush Tip" android:textColor="@color/accent_teal"
                        android:textSize="13sp" android:fontFamily="@font/sf_pro_display_medium" />
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Discard the first 10-15 minutes of rain (first flush) as it washes pollutants off the roof. Install a first-flush diverter to automate this and improve water quality."
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:lineSpacingExtra="4sp" />
            </LinearLayout>
        </FrameLayout>
        <!-- Tip 3 -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_ai_card" android:padding="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/bg_glass_chip" android:layout_marginEnd="12dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_gravity="center" android:src="@drawable/ic_plant" android:tint="@color/accent_lime" />
                    </FrameLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Usage Tip for Bangalore" android:textColor="@color/accent_lime"
                        android:textSize="13sp" android:fontFamily="@font/sf_pro_display_medium" />
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Bangalore's water tariff peaks in summer. Use your stored rainwater for toilet flushing and garden watering first — these are the highest-cost activities per litre."
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:lineSpacingExtra="4sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</ScrollView>
