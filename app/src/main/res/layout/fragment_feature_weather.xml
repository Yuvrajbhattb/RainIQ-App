<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fillViewport="false" android:clipToPadding="false"
    android:overScrollMode="never" android:paddingTop="116dp" android:paddingBottom="160dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp">
        <!-- Hero weather card -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="200dp"
            android:background="@drawable/bg_glass_water_card" android:padding="24dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="horizontal" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Bangalore" android:textColor="@color/text_secondary"
                        android:textSize="14sp" android:fontFamily="@font/sf_pro_display_regular" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="28°C" android:textColor="@color/text_primary"
                        android:textSize="56sp" android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Partly Cloudy" android:textColor="@color/accent_teal"
                        android:textSize="16sp" android:fontFamily="@font/sf_pro_display_regular" />
                </LinearLayout>
                <ImageView android:layout_width="80dp" android:layout_height="80dp"
                    android:src="@drawable/ic_cloud_sun" android:tint="@color/accent_teal" />
            </LinearLayout>
        </FrameLayout>
        <!-- Rain probability card -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card" android:padding="20dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RAIN PROBABILITY" android:textColor="@color/accent_teal"
                    android:textSize="10sp" android:fontFamily="@font/sf_pro_display_medium"
                    android:letterSpacing="0.12" android:layout_marginBottom="16dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Today" android:textColor="@color/text_tertiary"
                            android:textSize="11sp" android:fontFamily="@font/sf_pro_display_regular" android:layout_marginBottom="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="72%" android:textColor="@color/accent_teal"
                            android:textSize="22sp" android:fontFamily="@font/sf_pro_display_medium" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tomorrow" android:textColor="@color/text_tertiary"
                            android:textSize="11sp" android:fontFamily="@font/sf_pro_display_regular" android:layout_marginBottom="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="45%" android:textColor="@color/text_primary"
                            android:textSize="22sp" android:fontFamily="@font/sf_pro_display_medium" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Day 3" android:textColor="@color/text_tertiary"
                            android:textSize="11sp" android:fontFamily="@font/sf_pro_display_regular" android:layout_marginBottom="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="88%" android:textColor="@color/accent_teal"
                            android:textSize="22sp" android:fontFamily="@font/sf_pro_display_medium" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
        <!-- Harvest prediction card -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card" android:padding="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PREDICTED HARVEST THIS WEEK"
                    android:textColor="@color/text_tertiary" android:textSize="10sp"
                    android:fontFamily="@font/sf_pro_display_medium" android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="~8,400 L" android:textColor="@color/accent_lime"
                    android:textSize="36sp" android:fontFamily="@font/sf_pro_display_medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Based on forecast and your 1,000 sq ft roof"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="4dp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</ScrollView>
