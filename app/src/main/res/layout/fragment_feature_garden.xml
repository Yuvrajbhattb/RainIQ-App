<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fillViewport="false" android:clipToPadding="false"
    android:overScrollMode="never" android:paddingTop="116dp" android:paddingBottom="160dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp">
        <!-- Available water card -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_water_card" android:padding="20dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="AVAILABLE WATER FOR GARDEN" android:textColor="@color/accent_teal"
                    android:textSize="10sp" android:fontFamily="@font/sf_pro_display_medium" android:letterSpacing="0.12" android:layout_marginBottom="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="450 L"
                        android:textColor="@color/accent_teal" android:textSize="42sp" android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tank is 45% full" android:textColor="@color/text_secondary"
                        android:textSize="13sp" android:fontFamily="@font/sf_pro_display_regular" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
        <!-- Crop planner -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CROPS YOU CAN GROW" android:textColor="@color/accent_lime"
            android:textSize="10sp" android:fontFamily="@font/sf_pro_display_medium" android:letterSpacing="0.12" android:layout_marginBottom="10dp" />
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card" android:padding="20dp" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip" android:layout_marginEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🌿" android:textSize="22sp" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Spinach" android:textColor="@color/text_primary" android:textSize="15sp" android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Needs 3 L/day · Can grow for 150 days"
                        android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✓" android:textColor="@color/accent_lime" android:textSize="18sp" android:fontFamily="@font/sf_pro_display_medium" />
            </LinearLayout>
        </FrameLayout>
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card" android:padding="20dp" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip" android:layout_marginEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🍅" android:textSize="22sp" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tomatoes" android:textColor="@color/text_primary" android:textSize="15sp" android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Needs 5 L/day · Can grow for 90 days"
                        android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✓" android:textColor="@color/accent_lime" android:textSize="18sp" android:fontFamily="@font/sf_pro_display_medium" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</ScrollView>
