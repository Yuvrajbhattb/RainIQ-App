<?xml version="1.0" encoding="utf-8"?>
<!-- History item list row layout -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <!-- Swipe Background (Delete) -->
    <FrameLayout
        android:id="@+id/swipeBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_glass_card"
        android:backgroundTint="@color/swipe_delete_bg"
        android:paddingEnd="24dp">
        
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical|end"
            android:src="@drawable/ic_trash"
            android:tint="@color/text_primary" />
    </FrameLayout>

    <!-- Foreground Card -->
    <FrameLayout
        android:id="@+id/cardForeground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_list_card"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Date Block -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:minWidth="48dp">
                
                <TextView
                    android:id="@+id/tvDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24"
                    style="@style/TextStyle.StatNumber"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary" />
                    
                <TextView
                    android:id="@+id/tvMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OCT"
                    style="@style/TextStyle.ChipLabel" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_inner"
                android:layout_marginHorizontal="16dp" />

            <!-- Details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/tvRainfall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45 mm rainfall"
                    style="@style/TextStyle.CardTitle" />
                    
                <TextView
                    android:id="@+id/tvRoofType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Concrete Roof"
                    style="@style/TextStyle.BodySecondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Saved Amount -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saved"
                    style="@style/TextStyle.ChipLabel" />
                    
                <TextView
                    android:id="@+id/tvSavedLiters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ 382 L"
                    style="@style/TextStyle.CardTitle"
                    android:textColor="@color/accent_lime"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>
</FrameLayout>
