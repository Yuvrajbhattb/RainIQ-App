<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_dashboard.xml — Home Dashboard screen
    Phase 3: Full content with Water Tank, Stats, Insights, and Streak.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollDashboard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="false"
    android:overScrollMode="never"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/dashboardContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="0dp"
        android:paddingBottom="160dp">

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- INLINE HOME HEADER (scrolls with page) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/inlineDashboardHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="0dp"
            android:paddingEnd="@dimen/screen_margin_horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="@dimen/space_16">

            <!-- Left: Logo icon + Brand name + Tagline -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Drop icon — larger than profile avatar for brand prominence -->
                <ImageView
                    android:id="@+id/ivAppLogo"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/app_name" />

                <!-- Brand text block -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/space_8">

                    <!-- Two-tone RainIQ title -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rain"
                            android:textColor="@color/text_primary"
                            android:textSize="39sp"
                            android:fontFamily="@font/sf_pro_display_bold"
                            android:letterSpacing="-0.014" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IQ"
                            android:textColor="@color/accent_teal"
                            android:textSize="39sp"
                            android:fontFamily="@font/sf_pro_display_bold"
                            android:letterSpacing="-0.014" />
                    </LinearLayout>

                    <!-- Tagline -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CALCULATE • CONSERVE • IMPACT"
                        android:textColor="@color/accent_teal"
                        android:textSize="7sp"
                        android:fontFamily="@font/sf_pro_display_medium"
                        android:letterSpacing="0.06"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: Notification + Profile buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:id="@+id/btnNotificationInline"
                    android:layout_width="@dimen/glass_icon_button_size"
                    android:layout_height="@dimen/glass_icon_button_size"
                    android:background="@drawable/bg_glass_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Notifications">
                    <ImageView
                        android:layout_width="@dimen/glass_icon_inner_size"
                        android:layout_height="@dimen/glass_icon_inner_size"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_bell"
                        android:importantForAccessibility="no" />
                    <View
                        android:layout_width="@dimen/notification_badge_size"
                        android:layout_height="@dimen/notification_badge_size"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_notification_badge" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btnProfileInline"
                    android:layout_width="@dimen/avatar_size"
                    android:layout_height="@dimen/avatar_size"
                    android:layout_marginStart="@dimen/space_10"
                    android:background="@drawable/bg_avatar_ring"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Profile">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_glass_button"
                        android:padding="2dp">
                        <TextView
                            android:id="@+id/tvAvatarInitialsInline"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="JS"
                            android:textColor="@color/accent_lime"
                            android:textSize="14sp"
                            android:fontFamily="@font/inter_semibold" />
                    </FrameLayout>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Status bar spacer (insets applied via padding from activity) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- DASHBOARD CONTENT (with horizontal padding) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_margin_horizontal"
            android:paddingEnd="@dimen/screen_margin_horizontal">

        <!-- 3A.1 Hero Section -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello, Yuvraj"
            style="@style/TextStyle.DisplayHero" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:text="Ready to save some water?"
            style="@style/TextStyle.BodyPrimary"
            android:textColor="@color/text_secondary" />

        <!-- 3A.2 Water Tank Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/space_32">

            <!-- Water Tank View -->
            <com.rainiq.components.WaterTankView
                android:id="@+id/waterTankView"
                android:layout_width="80dp"
                android:layout_height="160dp" />

            <!-- Tank Stats -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/space_24">

                <TextView
                    android:id="@+id/tvCurrentLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="450 L"
                    style="@style/TextStyle.DisplayHero" />

                <TextView
                    android:id="@+id/tvTankCapacity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="of 1,000 L capacity"
                    style="@style/TextStyle.BodySecondary"
                    android:layout_marginTop="@dimen/space_4" />

                <!-- Status Chip -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_chip"
                    android:layout_marginTop="@dimen/space_12"
                    android:paddingStart="@dimen/space_12"
                    android:paddingEnd="@dimen/space_12"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/dotTankStatus"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_notification_badge"
                            android:backgroundTint="@color/accent_teal" />

                        <TextView
                            android:id="@+id/tvTankStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Looking good!"
                            style="@style/TextStyle.ChipLabel"
                            android:textColor="@color/accent_teal" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 3A.3 Today's Water Insight -->
        <FrameLayout
            android:id="@+id/cardInsight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_insight_card"
            android:layout_marginTop="@dimen/space_32"
            android:padding="@dimen/space_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sparkle"
                    android:tint="@color/accent_lime"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/space_12">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/todays_insight"
                        style="@style/TextStyle.CardSubtitle"
                        android:textColor="@color/accent_lime" />

                    <TextView
                        android:id="@+id/tvInsightText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="You saved 45L today. This is enough for 3 washing machine cycles!"
                        style="@style/TextStyle.BodyPrimary" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- 3A.4 Stats Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/space_24">

            <!-- Total Savings -->
            <FrameLayout
                android:id="@+id/cardTotalSavings"
                android:layout_width="0dp"
                android:layout_height="@dimen/stat_card_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_8"
                android:background="@drawable/bg_glass_stat_card"
                android:padding="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="bottom">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_savings"
                        style="@style/TextStyle.CardSubtitle" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvTotalSavings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,240"
                        style="@style/TextStyle.StatNumber" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Liters"
                        style="@style/TextStyle.StatUnit" />
                </LinearLayout>
            </FrameLayout>

            <!-- Monthly Goal -->
            <FrameLayout
                android:id="@+id/cardMonthlyGoal"
                android:layout_width="0dp"
                android:layout_height="@dimen/stat_card_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_8"
                android:background="@drawable/bg_glass_stat_card"
                android:padding="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="bottom">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monthly_goal"
                        style="@style/TextStyle.CardSubtitle" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvMonthlyGoalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2,000"
                        style="@style/TextStyle.StatNumber"
                        android:textColor="@color/text_primary" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Liters"
                        style="@style/TextStyle.StatUnit" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- 3A.5 Goal Progress Card -->
        <FrameLayout
            android:id="@+id/cardGoalProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:background="@drawable/bg_glass_card"
            android:padding="@dimen/space_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Goal Progress"
                        style="@style/TextStyle.CardTitle" />
                        
                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                        
                    <TextView
                        android:id="@+id/tvGoalPercentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="62%"
                        style="@style/TextStyle.CardSubtitle"
                        android:textColor="@color/accent_lime" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbGoalProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="@dimen/space_12"
                    android:progressDrawable="@drawable/bg_progress_bar"
                    android:max="100"
                    android:progress="62" />

            </LinearLayout>
        </FrameLayout>

        <!-- 3A.6 7-Day Streak Card -->
        <FrameLayout
            android:id="@+id/cardStreak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:background="@drawable/bg_glass_card"
            android:padding="@dimen/space_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7-Day Streak"
                    style="@style/TextStyle.CardTitle" />

                <!-- Day circles -->
                <LinearLayout
                    android:id="@+id/streakDaysContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:orientation="horizontal"
                    android:weightSum="7">
                    
                    <!-- Days will be populated programmatically -->
                    
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        </LinearLayout><!-- end inner content wrapper -->

    </LinearLayout><!-- end dashboardContent -->
</ScrollView>
