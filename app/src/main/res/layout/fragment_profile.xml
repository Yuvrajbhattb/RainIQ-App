<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_profile.xml — User Profile & Settings sheet
    Opens via header avatar button (not bottom nav)
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="false"
    android:clipToPadding="false"
    android:overScrollMode="never"
    android:paddingTop="116dp"
    android:paddingBottom="160dp"
    android:background="@color/bg_dark">

    <LinearLayout
        android:id="@+id/profileContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp">

        <!-- Header label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROFILE"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:fontFamily="@font/sf_pro_display_medium"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <!-- Profile Card -->
        <FrameLayout
            android:id="@+id/cardProfileEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_avatar_ring">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_glass_button"
                        android:padding="2dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="JS"
                            android:textColor="@color/accent_teal"
                            android:textSize="18sp"
                            android:fontFamily="@font/inter_semibold" />
                    </FrameLayout>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rahul"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:fontFamily="@font/sf_pro_display_medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="rahul@example.com"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="@font/sf_pro_display_regular"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_tertiary" />
            </LinearLayout>
        </FrameLayout>

        <!-- Roof Setup Summary -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MY SETUP"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:fontFamily="@font/sf_pro_display_medium"
            android:letterSpacing="0.15"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card">

            <!-- Roof Area -->
            <LinearLayout
                android:id="@+id/rowRoofArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    android:tint="@color/accent_teal" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Roof Area"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular"
                    android:layout_marginStart="16dp" />

                <TextView
                    android:id="@+id/tvRoofAreaValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1,000 sq ft"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_tertiary" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginStart="56dp"/>

            <!-- Tank Capacity -->
            <LinearLayout
                android:id="@+id/rowTankCapacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_drop"
                    android:tint="@color/accent_teal" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tank Capacity"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular"
                    android:layout_marginStart="16dp" />

                <TextView
                    android:id="@+id/tvTankCapacityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500 L"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_tertiary" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginStart="56dp"/>

            <!-- City -->
            <LinearLayout
                android:id="@+id/rowCity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_map_pin"
                    android:tint="@color/accent_teal" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="City"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular"
                    android:layout_marginStart="16dp" />

                <TextView
                    android:id="@+id/tvCityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bangalore"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_tertiary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Preferences Group -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFERENCES"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:fontFamily="@font/sf_pro_display_medium"
            android:letterSpacing="0.15"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card">

            <LinearLayout
                android:id="@+id/rowUnits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_drop" android:tint="@color/text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Measurement Units"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:layout_marginStart="16dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Liters" android:textColor="@color/text_secondary"
                    android:textSize="13sp" android:layout_marginEnd="8dp" />
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_tertiary" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginStart="56dp"/>

            <LinearLayout
                android:id="@+id/rowTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_cloud_sun" android:tint="@color/text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Dark Mode"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:layout_marginStart="16dp" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginStart="56dp"/>

            <LinearLayout
                android:id="@+id/rowRainAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_cloud_rain" android:tint="@color/accent_teal" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Rain Alerts"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:layout_marginStart="16dp" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchRainAlerts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginStart="56dp"/>

            <LinearLayout
                android:id="@+id/rowReminders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_bell" android:tint="@color/text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Daily Reminders"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:layout_marginStart="16dp" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchReminders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- Data Group -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DATA &amp; PRIVACY"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:fontFamily="@font/sf_pro_display_medium"
            android:letterSpacing="0.15"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card">

            <LinearLayout
                android:id="@+id/rowExport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_share" android:tint="@color/text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Export History"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:layout_marginStart="16dp" />
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_tertiary" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginStart="56dp"/>

            <LinearLayout
                android:id="@+id/rowClearData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_trash" android:tint="@color/accent_red_soft" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Clear All Data"
                    android:textColor="@color/accent_red_soft" android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular" android:layout_marginStart="16dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RainIQ v1.0.0"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="@font/sf_pro_display_regular"
            android:gravity="center"
            android:layout_marginTop="32dp" />

    </LinearLayout>
</ScrollView>
