<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_onboarding_page3.xml
    Screen 3: "Powered by AI" — animated AI chat bubbles + feature cards
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingEnd="28dp">

    <TextView
        android:id="@+id/tvLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="POWERED BY GEMINI AI"
        android:textColor="#80FFFFFF"
        android:textSize="11sp"
        android:fontFamily="@font/sf_pro_display_medium"
        android:letterSpacing="0.1"
        android:alpha="0" />

    <!-- Headline -->
    <TextView
        android:id="@+id/tvHeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Your AI water\nwisdom companion."
        android:textSize="32sp"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/sf_pro_display_medium"
        android:letterSpacing="-0.018"
        android:lineSpacingExtra="4sp"
        android:alpha="0" />

    <!-- AI Chat Mock UI -->
    <LinearLayout
        android:id="@+id/chatContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp">

        <!-- User bubble (right-aligned) -->
        <FrameLayout
            android:id="@+id/bubbleUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="@drawable/bg_glass_chip"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="12dp"
            android:alpha="0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What can I grow with 500L?"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/sf_pro_display_regular" />
        </FrameLayout>

        <!-- AI thinking dots -->
        <LinearLayout
            android:id="@+id/thinkingDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:background="@drawable/bg_glass_card"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <View android:id="@+id/dot1" android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_notification_badge"
                android:backgroundTint="@color/text_tertiary" android:layout_marginEnd="4dp"/>
            <View android:id="@+id/dot2" android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_notification_badge"
                android:backgroundTint="@color/text_tertiary" android:layout_marginEnd="4dp"/>
            <View android:id="@+id/dot3" android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_notification_badge"
                android:backgroundTint="@color/text_tertiary"/>
        </LinearLayout>

        <!-- AI response bubble (left-aligned) -->
        <FrameLayout
            android:id="@+id/bubbleAi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:background="@drawable/bg_glass_ai_card"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:alpha="0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_sparkle"
                        android:tint="@color/accent_teal"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Jal-Bot"
                        android:textColor="@color/accent_teal"
                        android:textSize="11sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAiResponse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/sf_pro_display_regular"
                    android:lineSpacingExtra="4sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Feature cards (stagger in) -->
    <LinearLayout
        android:id="@+id/featureCards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="180dp"
        android:layout_marginTop="12dp">

        <!-- Card 1 -->
        <FrameLayout
            android:id="@+id/card1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_list_card"
            android:padding="14dp"
            android:layout_marginBottom="8dp"
            android:alpha="0">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_sparkle" android:tint="@color/accent_teal" android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Personalised AI Tips" style="@style/TextStyle.CardTitle"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Based on your roof size and city" style="@style/TextStyle.BodySecondary"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Card 2 -->
        <FrameLayout
            android:id="@+id/card2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_list_card"
            android:padding="14dp"
            android:layout_marginBottom="8dp"
            android:alpha="0">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_plant" android:tint="@color/accent_lime" android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Garden Planner" style="@style/TextStyle.CardTitle"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Grow crops with your harvested water" style="@style/TextStyle.BodySecondary"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Card 3 -->
        <FrameLayout
            android:id="@+id/card3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_list_card"
            android:padding="14dp"
            android:alpha="0">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_drop" android:tint="@color/accent_teal" android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ask Jal-Bot" style="@style/TextStyle.CardTitle"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Q&amp;A about water harvesting" style="@style/TextStyle.BodySecondary"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
