<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_ai_tips.xml — AI Tips screen (Screen 5)
    Phase 4A: List of eco-tips and a floating "Ask AI" input bar.
    Title is handled by layout_screen_header in MainActivity.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content (Scrolling List) -->
    <!-- paddingTop = ~80dp to clear the screen header bar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAiTips"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="116dp"
        android:paddingBottom="200dp"
        android:paddingHorizontal="@dimen/screen_margin_horizontal"
        android:overScrollMode="never"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_ai_tip" />

    <!-- Floating "Ask AI" Input Bar (At bottom, above nav) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="116dp"
        android:layout_marginHorizontal="@dimen/screen_margin_horizontal"
        android:background="@drawable/bg_glass_input"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:elevation="8dp">

        <EditText
            android:id="@+id/etAskAi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Ask for water-saving advice..."
            android:textColorHint="@color/text_tertiary"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:inputType="text"
            android:maxLines="1"
            style="@style/TextStyle.BodyPrimary" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_glass_chip"
            android:src="@drawable/ic_target"
            android:tint="@color/accent_lime"
            android:scaleType="centerInside"
            android:padding="10dp" />
    </LinearLayout>

</FrameLayout>
