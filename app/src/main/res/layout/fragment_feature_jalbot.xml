<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:paddingTop="116dp">
    <!-- Chat Messages -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:clipToPadding="false"
        android:overScrollMode="never" android:paddingHorizontal="20dp" android:paddingBottom="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Bot intro -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="bottom" android:layout_marginBottom="16dp">
                <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                    android:background="@drawable/bg_glass_chip" android:layout_marginEnd="10dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_gravity="center" android:src="@drawable/ic_sparkle"
                        android:tint="@color/accent_teal" />
                </FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_glass_ai_card"
                    android:padding="16dp" android:layout_marginEnd="48dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Hi! I'm Jal-Bot 💧 Ask me anything about rainwater harvesting, your roof setup, or how to save more water." android:textColor="@color/text_primary"
                        android:textSize="14sp" android:fontFamily="@font/sf_pro_display_regular" android:lineSpacingExtra="3sp" />
                </FrameLayout>
            </LinearLayout>
            <!-- User message -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="bottom" android:layout_marginBottom="16dp">
                <View android:layout_width="48dp" android:layout_height="0dp" />
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_glass_card"
                    android:padding="16dp" android:layout_marginStart="48dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="How much water can my 1000 sq ft roof collect in a year?"
                        android:textColor="@color/text_primary" android:textSize="14sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:lineSpacingExtra="3sp" />
                </FrameLayout>
            </LinearLayout>
            <!-- Bot answer -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="bottom" android:layout_marginBottom="16dp">
                <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                    android:background="@drawable/bg_glass_chip" android:layout_marginEnd="10dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_gravity="center" android:src="@drawable/ic_sparkle"
                        android:tint="@color/accent_teal" />
                </FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_glass_ai_card"
                    android:padding="16dp" android:layout_marginEnd="48dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Great question! With Bangalore's average rainfall of ~900mm/year and a 1,000 sq ft (93 m²) roof, you could collect:"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:fontFamily="@font/sf_pro_display_regular" android:lineSpacingExtra="3sp" android:layout_marginBottom="12dp" />
                        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:background="@drawable/bg_glass_chip" android:padding="12dp">
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:text="93 m² × 900mm × 0.8 (efficiency) ≈ 66,960 litres/year" android:textColor="@color/accent_teal"
                                android:textSize="13sp" android:fontFamily="@font/sf_pro_display_medium" android:gravity="center" />
                        </FrameLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="That's about ₹1,675/year in water bill savings! 🌱"
                            android:textColor="@color/accent_lime" android:textSize="13sp"
                            android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="10dp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <!-- Input Bar -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="16dp" android:background="@drawable/bg_glass_card">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <EditText android:id="@+id/etChatInput"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="Ask Jal-Bot..."
                android:textColorHint="@color/text_tertiary" android:textColor="@color/text_primary"
                android:background="@drawable/bg_glass_chip" android:padding="12dp"
                android:textSize="14sp" android:fontFamily="@font/sf_pro_display_regular"
                android:inputType="text" android:maxLines="1" android:layout_marginEnd="10dp" />
            <FrameLayout android:id="@+id/btnSend"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="@drawable/bg_button_primary" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:layout_gravity="center" android:src="@drawable/ic_sparkle"
                    android:tint="@color/text_on_light_glass" />
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
