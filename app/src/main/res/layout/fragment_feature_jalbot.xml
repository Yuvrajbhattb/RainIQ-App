<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_feature_jalbot.xml — Jal-Bot AI chat screen
    Dynamic chat with input bar at bottom.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="116dp">

    <!-- Chat Messages (scrollable) -->
    <ScrollView
        android:id="@+id/scrollChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Input Bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@drawable/bg_glass_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etChatInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Ask Jal-Bot..."
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_glass_chip"
                android:padding="12dp"
                android:textSize="14sp"
                android:fontFamily="@font/sf_pro_display_regular"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionSend"
                android:layout_marginEnd="10dp" />

            <FrameLayout
                android:id="@+id/btnSend"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_primary"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivSendIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_sparkle"
                    android:tint="@color/text_on_light_glass" />
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
