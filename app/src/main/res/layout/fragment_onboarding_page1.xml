<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_onboarding_page1.xml
    Screen 1: "Every Drop, Counted"
    Illustration fills the top ~58% of screen.
    Text sits in a clean dark section below — no overlap.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deepest"
    android:orientation="vertical">

    <!-- Illustration — takes top 58% of the screen -->
    <ImageView
        android:id="@+id/imgIllustration"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="58"
        android:scaleType="centerCrop"
        android:src="@drawable/illustration1"
        android:importantForAccessibility="no" />

    <!-- Text section — clean dark background, bottom 42% -->
    <LinearLayout
        android:id="@+id/textContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="42"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="188dp">

        <!-- "Every Drop," — white -->
        <TextView
            android:id="@+id/tvHeadlinePart1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Every Drop,"
            android:textSize="40sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/sf_pro_display_bold"
            android:letterSpacing="-0.022"
            android:alpha="0" />

        <!-- "Counted." — teal -->
        <TextView
            android:id="@+id/tvHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Counted."
            android:textSize="40sp"
            android:textColor="@color/accent_teal"
            android:fontFamily="@font/sf_pro_display_bold"
            android:letterSpacing="-0.022"
            android:alpha="0" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="RainIQ turns your rooftop into a measurable water asset. Start tracking your rainwater savings - one drop at a time."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/sf_pro_display_regular"
            android:lineSpacingExtra="4sp"
            android:alpha="0" />

    </LinearLayout>

    <!-- Hidden view so binding doesn't crash (chipTagline was used in old code) -->
    <View
        android:id="@+id/chipTagline"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
