<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_onboarding_setup.xml
    Screen 5: Roof Setup Form — collects user's roof data before entering the app
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvSetupLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="80dp"
            android:text="ONE-TIME SETUP"
            android:textColor="@color/accent_lime"
            style="@style/TextStyle.ChipLabel"
            android:alpha="0" />

        <TextView
            android:id="@+id/tvSetupHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Set Up Your Roof"
            android:textSize="34sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/sf_pro_display_medium"
            android:letterSpacing="-0.020"
            android:alpha="0" />

        <TextView
            android:id="@+id/tvSetupSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp"
            android:text="This lets us calculate exactly how much water your roof can harvest."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/sf_pro_display_regular"
            android:lineSpacingExtra="4sp"
            android:alpha="0" />

        <!-- Field 1: Roof Area -->
        <LinearLayout
            android:id="@+id/llRoofArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:alpha="0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Roof Area (sq ft)"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/sf_pro_display_medium"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>

            <EditText
                android:id="@+id/etRoofArea"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_glass_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:hint="e.g. 1000"
                android:textSize="15sp"
                android:fontFamily="@font/sf_pro_display_regular"
                android:inputType="numberDecimal" />

            <TextView
                android:id="@+id/tvRoofAreaError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_red_soft"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_marginStart="4dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Field 2: Tank Capacity -->
        <LinearLayout
            android:id="@+id/llTankCapacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:alpha="0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tank Capacity (liters)"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/sf_pro_display_medium"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>

            <EditText
                android:id="@+id/etTankCapacity"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_glass_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:hint="e.g. 500"
                android:textSize="15sp"
                android:fontFamily="@font/sf_pro_display_regular"
                android:inputType="numberDecimal" />

            <TextView
                android:id="@+id/tvTankCapacityError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_red_soft"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_marginStart="4dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Field 3: Roof Material Dropdown -->
        <LinearLayout
            android:id="@+id/llRoofMaterial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:alpha="0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Roof Material"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/sf_pro_display_medium"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tvRoofMaterial"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_glass_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="40dp"
                    android:gravity="center_vertical"
                    android:textColor="@color/text_primary"
                    android:text="Concrete/RCC  (×0.85)"
                    android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_tertiary"
                    android:rotation="90" />
            </FrameLayout>
        </LinearLayout>

        <!-- Field 4: City -->
        <LinearLayout
            android:id="@+id/llCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"
            android:alpha="0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="City / Location"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/sf_pro_display_medium"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_map_pin"
                    android:tint="@color/text_tertiary"
                    android:translationZ="2dp" />
                <EditText
                    android:id="@+id/etCity"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_glass_input"
                    android:paddingStart="44dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:hint="e.g. Bangalore"
                    android:textSize="15sp"
                    android:fontFamily="@font/sf_pro_display_regular"
                    android:inputType="textCapWords"
                    android:imeOptions="actionDone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvCityError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_red_soft"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_marginStart="4dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Live Preview Card (visible when all fields filled) -->
        <FrameLayout
            android:id="@+id/previewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_insight_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estimated monthly harvest"
                    style="@style/TextStyle.CardSubtitle"
                    android:textColor="@color/accent_lime" />

                <TextView
                    android:id="@+id/tvPreviewValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="~0 L"
                    android:textSize="28sp"
                    android:textColor="@color/accent_lime"
                    android:fontFamily="@font/sf_pro_display_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Area × Avg. Rainfall × Runoff"
                    style="@style/TextStyle.BodySecondary" />
            </LinearLayout>
        </FrameLayout>

        <!-- Save Button -->
        <FrameLayout
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_primary"
            android:alpha="0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="START SAVING WATER 💧"
                style="@style/TextStyle.ButtonCta" />
        </FrameLayout>

    </LinearLayout>
</ScrollView>
