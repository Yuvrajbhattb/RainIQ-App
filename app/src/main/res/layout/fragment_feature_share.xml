<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fillViewport="false" android:clipToPadding="false"
    android:overScrollMode="never" android:paddingTop="116dp" android:paddingBottom="160dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp">
        <!-- Impact card to share -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="280dp"
            android:background="@drawable/bg_glass_water_card" android:padding="24dp" android:layout_marginBottom="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="48dp" android:layout_height="48dp"
                    android:src="@drawable/ic_drop" android:tint="@color/accent_teal" android:layout_marginBottom="16dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="My Water Story" android:textColor="@color/text_primary"
                    android:textSize="20sp" android:fontFamily="@font/sf_pro_display_medium" android:gravity="center" android:layout_marginBottom="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="This month I saved" android:textColor="@color/text_secondary"
                    android:textSize="14sp" android:fontFamily="@font/sf_pro_display_regular" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="12,450 L" android:textColor="@color/accent_teal"
                    android:textSize="40sp" android:fontFamily="@font/sf_pro_display_medium" android:gravity="center" android:layout_marginTop="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="of rainwater 💧" android:textColor="@color/text_secondary"
                    android:textSize="14sp" android:fontFamily="@font/sf_pro_display_regular" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="via RainIQ" android:textColor="@color/text_tertiary"
                    android:textSize="11sp" android:fontFamily="@font/sf_pro_display_regular" android:gravity="center" android:layout_marginTop="16dp" />
            </LinearLayout>
        </FrameLayout>
        <!-- Share buttons -->
        <FrameLayout android:id="@+id/btnShareWhatsapp"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@drawable/bg_button_primary"
            android:clickable="true" android:focusable="true" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:text="Share on WhatsApp"
                android:textColor="@color/text_on_light_glass" android:textSize="15sp"
                android:fontFamily="@font/sf_pro_display_medium" />
        </FrameLayout>
        <FrameLayout android:id="@+id/btnShareImage"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@drawable/bg_glass_card"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:text="Save as Image"
                android:textColor="@color/text_primary" android:textSize="15sp"
                android:fontFamily="@font/sf_pro_display_medium" />
        </FrameLayout>
    </LinearLayout>
</ScrollView>
