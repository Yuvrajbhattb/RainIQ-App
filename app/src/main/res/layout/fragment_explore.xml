<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_explore.xml — Explore / More Features screen (Bottom Nav tab 5)
    Showcases all app features in a premium card grid layout.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="false"
    android:clipToPadding="false"
    android:overScrollMode="never"
    android:paddingTop="116dp"
    android:paddingBottom="160dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp">

        <!-- ═══════════════════════════════════════ -->
        <!-- WATER TOOLS -->
        <!-- ═══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WATER TOOLS"
            android:textColor="@color/accent_teal"
            android:textSize="10sp"
            android:fontFamily="@font/sf_pro_display_medium"
            android:letterSpacing="0.15"
            android:layout_marginBottom="10dp" />

        <!-- Track Rain Entry -->
        <FrameLayout
            android:id="@+id/cardTrackRain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_water_card"
            android:padding="20dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_cloud_rain" android:tint="@color/accent_teal" />
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Track Rain Entry"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Log today's rainfall manually"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>

                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/accent_teal" />
            </LinearLayout>
        </FrameLayout>

        <!-- History -->
        <FrameLayout
            android:id="@+id/cardHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_water_card"
            android:padding="20dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_calendar" android:tint="@color/accent_teal" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rainfall History"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="View all past records &amp; trends"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/accent_teal" />
            </LinearLayout>
        </FrameLayout>

        <!-- Weather -->
        <FrameLayout
            android:id="@+id/cardWeather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_water_card"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_cloud_sun" android:tint="@color/accent_teal" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Live Weather"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Forecast &amp; rain probability"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/accent_teal" />
            </LinearLayout>
        </FrameLayout>

        <!-- ═══════════════════════════════════════ -->
        <!-- AI FEATURES -->
        <!-- ═══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI FEATURES"
            android:textColor="@color/accent_teal"
            android:textSize="10sp"
            android:fontFamily="@font/sf_pro_display_medium"
            android:letterSpacing="0.15"
            android:layout_marginBottom="10dp" />

        <!-- Jal-Bot -->
        <FrameLayout
            android:id="@+id/cardJalBot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_ai_card"
            android:padding="20dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_sparkle" android:tint="@color/accent_teal" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Jal-Bot AI"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ask anything about water harvesting"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/accent_teal" />
            </LinearLayout>
        </FrameLayout>

        <!-- AI Tips -->
        <FrameLayout
            android:id="@+id/cardAiTips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_ai_card"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_plant" android:tint="@color/accent_teal" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Personalised AI Tips"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Smart tips based on your setup &amp; city"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/accent_teal" />
            </LinearLayout>
        </FrameLayout>

        <!-- ═══════════════════════════════════════ -->
        <!-- GROWTH & IMPACT -->
        <!-- ═══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GROWTH &amp; IMPACT"
            android:textColor="@color/accent_lime"
            android:textSize="10sp"
            android:fontFamily="@font/sf_pro_display_medium"
            android:letterSpacing="0.15"
            android:layout_marginBottom="10dp" />

        <!-- Goals -->
        <FrameLayout
            android:id="@+id/cardGoals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_target" android:tint="@color/accent_lime" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Goals"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Set &amp; track monthly water goals"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_tertiary" />
            </LinearLayout>
        </FrameLayout>

        <!-- Achievements -->
        <FrameLayout
            android:id="@+id/cardAchievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_trophy" android:tint="@color/accent_lime" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Achievements"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Badges, streaks &amp; milestones"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_tertiary" />
            </LinearLayout>
        </FrameLayout>

        <!-- Impact Report -->
        <FrameLayout
            android:id="@+id/cardReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_chart_bar" android:tint="@color/accent_lime" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Impact Report"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Monthly savings, trees &amp; money"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_tertiary" />
            </LinearLayout>
        </FrameLayout>

        <!-- Garden Planner -->
        <FrameLayout
            android:id="@+id/cardGarden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_plant" android:tint="@color/accent_lime" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Garden Planner"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Grow crops with your harvested water"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_tertiary" />
            </LinearLayout>
        </FrameLayout>

        <!-- Share Impact -->
        <FrameLayout
            android:id="@+id/cardShare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:clipToOutline="true">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_glass_chip">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_share" android:tint="@color/accent_lime" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Share Impact"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:fontFamily="@font/sf_pro_display_medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Inspire others with your water story"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:fontFamily="@font/sf_pro_display_regular" android:layout_marginTop="3dp" />
                </LinearLayout>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_tertiary" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</ScrollView>
