<?xml version="1.0" encoding="utf-8"?>
<!--
    item_ai_tip.xml — Card layout for an individual AI tip
    Phase 4A: Glassmorphic card with category chip, title, body, and potential savings badge.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp">

    <FrameLayout
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Category Chip & Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_chip"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gardening"
                        style="@style/TextStyle.ChipLabel"
                        android:textColor="@color/accent_lime" />
                </FrameLayout>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/ivIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_sparkle"
                    android:tint="@color/text_tertiary"
                    android:importantForAccessibility="no" />
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Optimize your sprinklers"
                style="@style/TextStyle.CardTitle"
                android:textSize="18sp" />

            <!-- Body -->
            <TextView
                android:id="@+id/tvBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Water your plants early in the morning or late in the evening to reduce evaporation. Adjust sprinkler heads to avoid watering the pavement."
                style="@style/TextStyle.BodyPrimary"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp" />

            <!-- Savings Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_drop"
                    android:tint="@color/accent_teal"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvSavings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Saves ~40L per week"
                    style="@style/TextStyle.BodySecondary"
                    android:textColor="@color/accent_teal" />
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>
</FrameLayout>
